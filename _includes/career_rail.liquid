<div class="career-rail" aria-label="Career timeline">
  <div class="career-rail-track">
    <div class="career-rail-row">

      <div class="career-stop" style="--stop-accent: #E84A27;">
        <div class="career-card career-card-top">
          <div class="career-badge" aria-hidden="true">
            <img src="{{ '/assets/img/career/uiuc.png' | relative_url }}" alt="" onerror="this.outerHTML='<span class=&quot;career-badge-letter&quot;>I</span>';">
          </div>
          <div class="career-meta">
            <div class="career-org">UIUC</div>
            <div class="career-role">B.S. Computer Science · Parallel Programming Lab</div>
          </div>
        </div>
        <div class="career-date">2021 – 2025</div>
      </div>

      <div class="career-stop" style="--stop-accent: #FF3621;">
        <div class="career-date">Summer 2023 · 2024</div>
        <div class="career-card career-card-bottom">
          <div class="career-badge" aria-hidden="true">
            <img src="{{ '/assets/img/career/databricks.png' | relative_url }}" alt="" onerror="this.outerHTML='<span class=&quot;career-badge-letter&quot;>D</span>';">
          </div>
          <div class="career-meta">
            <div class="career-org">Databricks</div>
            <div class="career-role">SWE Intern '23 → Research Scientist Intern '24</div>
          </div>
        </div>
      </div>

      <div class="career-stop" style="--stop-accent: #4B2E83;">
        <div class="career-card career-card-top">
          <div class="career-badge" aria-hidden="true">
            <img src="{{ '/assets/img/career/uw.png' | relative_url }}" alt="" onerror="this.outerHTML='<span class=&quot;career-badge-letter&quot;>W</span>';">
          </div>
          <div class="career-meta">
            <div class="career-org">UW</div>
            <div class="career-role">PhD · advised by Stephanie Wang &amp; Luis Ceze</div>
          </div>
        </div>
        <div class="career-date">2025 – now</div>
      </div>

    </div>
  </div>
</div>
