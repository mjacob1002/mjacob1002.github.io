@misc{frisella2026piper,
      title={Piper: A Programmable Distributed Training System},
      author={Frisella, Megan and Tiwari, Shubham and Ruan, Andy and Pan, Yi and Gustafson, Parker and Jacob, Mat and Bernstein, Gilbert and Wang, Stephanie},
      year={2026},
      month={6},
      eprint={2606.11169},
      archivePrefix={arXiv},
      primaryClass={cs.DC},
      url={https://arxiv.org/abs/2606.11169},
      doi={10.48550/arXiv.2606.11169},
      abstract={Large-scale model training increasingly relies on composing multiple parallelism strategies, such as data, pipeline, and expert parallelism, together with memory-saving optimizations like ZeRO. Piper lets users declare distributed training strategies through model annotations and scheduling directives that transform an intermediate representation. Piper compiles per-device execution plans and executes them with a distributed runtime agnostic to the strategy, maintaining performance parity with established approaches while enabling efficiency gains in composed strategies like DeepSeek-V3's DualPipe.},
      pdf={papers/piper.pdf},
      categories={MLSys},
      category_slugs={mlsys},
      selected={true}
}

@misc{pan2026brane,
      title={Natural Language Query to Configuration for Retrieval Agents},
      author={Pan, Melissa Z. and Arabzadeh, Negar and Jacob, Mathew and Kazhamiaka, Fiodar and Choukse, Esha and Zaharia, Matei},
      year={2026},
      month={5},
      eprint={2605.27361},
      archivePrefix={arXiv},
      primaryClass={cs.AI},
      url={https://arxiv.org/abs/2605.27361},
      doi={10.48550/arXiv.2605.27361},
      abstract={Modern retrieval agents present numerous configuration options including LLM choice, retriever selection, document count, hop number, and synthesis strategy. We introduce BRANE, which uses an LLM to convert each query into workload-specific characteristics, then trains a lightweight per-configuration predictor. The system selects optimal pipeline configurations at inference time to balance cost and accuracy tradeoffs. Across multiple benchmarks, our approach matches the best fixed configuration's accuracy at up to 89% lower cost.},
      pdf={papers/brane.pdf},
      categories={Agents, Information Retrieval},
      category_slugs={agents, ir},
      selected={true}
}

@article{unknown,
year = {2024},
